generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MovementType {
  expense
  income
}

enum Account {
  efectivo
  banco
  tarjeta_credito
}

model AllowedUser {
  id             String   @id @default(cuid())
  telegramUserId String   @unique
  name           String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@map("allowed_users")
}

model Movement {
  id             String       @id @default(cuid())
  telegramUserId String
  type           MovementType
  amount         Decimal      @db.Decimal(12, 2)
  category       String
  account        Account
  note           String?
  createdAt      DateTime     @default(now())

  @@index([telegramUserId])
  @@index([createdAt])
  @@index([telegramUserId, createdAt])
  @@map("movements")
}
